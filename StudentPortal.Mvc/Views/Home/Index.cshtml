                        <h1 class="display-5 text-warning mb-3">📖</h1>
                        <h5 class="fw-bold text-dark">Môn học</h5>
                        <p class="text-muted small">Tín chỉ, Tiên quyết</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col">
            <a asp-controller="CourseClasses" asp-action="Index" class="text-decoration-none">
